{
  "name": "optum_automation_test",
  "version": "1.0.0",
  "description": "Lightweight Playwright automation trial repo for Web and Mobile smoke testing, designed to avoid over-engineering and support rapid experimentation.",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:uat": "ENV=uat npx playwright test",
    "test:login": "npx playwright test web/tests/login.spec.ts",
    "test:home": "npx playwright test web/tests/home.spec.ts",
    "test:explore": "npx playwright test web/tests/explore.spec.ts",
    "test:benefits": "npx playwright test web/tests/benefits.spec.ts",
    "test:rewards": "npx playwright test web/tests/rewards.spec.ts",
    "test:settings": "npx playwright test web/tests/settings.spec.ts",
    "test:health-survey": "npx playwright test web/tests/health-survey.spec.ts",
    "test:signout": "npx playwright test web/tests/signout.spec.ts",
    "report": "npx playwright show-report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rashmi-BR/Optum_automation_test.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Rashmi-BR/Optum_automation_test/issues"
  },
  "homepage": "https://github.com/Rashmi-BR/Optum_automation_test#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.2"
  },
  "dependencies": {
    "@capillary/optum-testing-ui-library": "file:../optum-testing-ui-library"
  }
}
